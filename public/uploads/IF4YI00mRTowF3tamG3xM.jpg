                $(this).attr("title","");
            },
            function() { 
                var title = $(this).attr("tmp_title");
                $(this).attr("title", title);
            });
            $("a").click(function(){
                var title = $(this).attr("tmp_title");
                $(this).attr("title", title);
            });
        });
        </script>
        
